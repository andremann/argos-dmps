e</includeInExport></field></fields><title>Will informed consent for data sharing and long term preservation be included in questionnaires dealing with personal data?</title><hasMultiplicity>false</hasMultiplicity><hasCommentField>false</hasCommentField></fieldSet></fieldSets><title>Ethics</title><sections/></section></sections></page></pages></descriptionTemplate><properties><fieldSets><fieldSet><fieldSetId>99299810-1a77-ac18-a55a-a38a763f1b96</fieldSetId><items><item><fields><field><fieldId>3f695a5a-3ef3-194f-bc92-655b296009b5</fieldId><booleanValue>false</booleanValue></field><field><fieldId>2c6e2b93-7beb-fa5b-5988-308b5d98c0bc</fieldId><textValue>No ethics or legal issues are foreseen that would prevent data sharing. An embargo period may apply purely for publication timing, not for ethical/legal reason</textValue></field></fields><ordinal>0</ordinal></item></items></fieldSet><fieldSet><fieldSetId>8e7fc1be-3038-c5a4-151a-407eade5d44d</fieldSetId><items><item><fields><field><fieldId>dd2f15e8-01c6-bbf4-4131-8d28ab120f0f</fieldId></field><field><fieldId>40150c0b-f013-cd0d-42fe-aefe50082875</fieldId><booleanValue>false</booleanValue></field></fields><ordinal>0</ordinal></item></items></fieldSet></fieldSets></properties></description></descriptions></plan>